rules_version = '2';
match /databases/{database}/documents {
  // Products - Anyone can read, only admins can write
  match /products/{product} {
    allow read: if true;
    allow write: if false; // Only via Firebase console or admin SDK
  }
  
  // Categories - Anyone can read, only admins can write
  match /categories/{category} {
    allow read: if true;
    allow write: if false;
  }
  
  // Orders - Authenticated users can create, admins can update
  match /orders/{order} {
    allow read: if request.auth != null;
    allow create: if request.auth != null;
    allow update: if request.auth != null;
  }
  
  // Users - Users can read/write their own data
  match /users/{userId} {
    allow read: if request.auth != null && request.auth.uid == userId;
    allow write: if request.auth != null && request.auth.uid == userId;
  }
  
  // Admins - Only readable by authenticated users
  match /admins/{admin} {
    allow read: if request.auth != null;
    allow write: if false;
  }
}
